{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{job=\"springforge-backend\"}[5m])",
          "legendFormat": "{{method}} {{uri}} {{status}}"
        }
      ]
    },
    {
      "title": "Response Time (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_server_requests_seconds_bucket{job=\"springforge-backend\"}[5m]))",
          "legendFormat": "{{uri}}"
        }
      ]
    },
    {
      "title": "Error Rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{status=~\"5..\"}[5m])) / sum(rate(http_server_requests_seconds_count[5m])) * 100",
          "legendFormat": "Error %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 1, "color": "yellow" },
              { "value": 5, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "title": "Active Requests",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 8 },
      "targets": [
        {
          "expr": "sum(http_server_requests_seconds_active_count{job=\"springforge-backend\"})",
          "legendFormat": "Active"
        }
      ]
    },
    {
      "title": "JVM Heap Memory",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{job=\"springforge-backend\", area=\"heap\"}",
          "legendFormat": "Used - {{id}}"
        },
        {
          "expr": "jvm_memory_max_bytes{job=\"springforge-backend\", area=\"heap\"}",
          "legendFormat": "Max - {{id}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      }
    },
    {
      "title": "Database Connection Pool",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "hikaricp_connections_active{job=\"springforge-backend\"}",
          "legendFormat": "Active"
        },
        {
          "expr": "hikaricp_connections_idle{job=\"springforge-backend\"}",
          "legendFormat": "Idle"
        },
        {
          "expr": "hikaricp_connections_max{job=\"springforge-backend\"}",
          "legendFormat": "Max"
        }
      ]
    },
    {
      "title": "Project Generations",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "rate(springforge_generation_total[5m])",
          "legendFormat": "Generations/s"
        },
        {
          "expr": "rate(springforge_generation_errors_total[5m])",
          "legendFormat": "Errors/s"
        }
      ]
    },
    {
      "title": "GC Pauses",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "rate(jvm_gc_pause_seconds_sum{job=\"springforge-backend\"}[5m])",
          "legendFormat": "{{action}} - {{cause}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Kafka Consumer Lag",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        {
          "expr": "kafka_consumer_lag_sum{job=\"springforge-backend\"}",
          "legendFormat": "{{topic}}"
        }
      ]
    }
  ],
  "schemaVersion": 38,
  "tags": ["springforge", "backend"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "SpringForge Backend",
  "uid": "springforge-backend"
}
