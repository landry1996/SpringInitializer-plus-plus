# ===========================================
# SpringForge Production Environment Variables
# ===========================================
# Copy this file to .env and fill in the values
# cp .env.example .env

# Domain (used for SSL certificate)
DOMAIN=your-domain.com

# Database
DB_PASSWORD=change-me-to-a-strong-password

# JWT - must be at least 64 characters for HS512
JWT_SECRET=change-me-to-a-random-64-plus-character-string-for-production-use-only

# CORS (comma-separated if multiple)
CORS_ORIGINS=https://your-domain.com

# Generation output directory (inside container)
GENERATION_OUTPUT_DIR=/app/generated

# Optional: Kafka (set to true to enable)
KAFKA_ENABLED=false
SPRING_KAFKA_BOOTSTRAP_SERVERS=

# Optional: Keycloak (set to true to enable)
KEYCLOAK_ENABLED=false
KEYCLOAK_ISSUER_URI=
