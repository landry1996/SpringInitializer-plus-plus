# ===========================================
# SpringForge Production Environment Variables
# ===========================================
# Copy this file to .env and fill in the values
# cp .env.example .env

# Domain (used for SSL certificate)
DOMAIN=your-domain.com

# Database
DB_PASSWORD=change-me-to-a-strong-password

# JWT - must be at least 64 characters for HS512
JWT_SECRET=change-me-to-a-random-64-plus-character-string-for-production-use-only

# CORS (comma-separated if multiple)
CORS_ORIGINS=https://your-domain.com

# Generation output directory (inside container)
GENERATION_OUTPUT_DIR=/app/generated

# Optional: Kafka (set to true to enable)
KAFKA_ENABLED=false
SPRING_KAFKA_BOOTSTRAP_SERVERS=

# Optional: Keycloak (set to true to enable)
KEYCLOAK_ENABLED=false
KEYCLOAK_ISSUER_URI=

# Optional: Object Storage (MinIO or filesystem)
STORAGE_TYPE=filesystem
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=springforge-generations

# Optional: Stripe Billing
STRIPE_SECRET_KEY=
STRIPE_PRO_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# Optional: AI / LLM
AI_PROVIDER=claude
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AI_MODEL=claude-sonnet-4-20250514

# Optional: Email Notifications (SMTP)
NOTIFICATION_EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=notifications@springforge.io
